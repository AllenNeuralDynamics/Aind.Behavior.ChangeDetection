# Default: text files normalized to LF in repo, converted on checkout as needed
*               text=auto eol=lf

# Code & docs: LF
*.py            text eol=lf
*.toml          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.md            text eol=lf
*.rst           text eol=lf
*.svg           text eol=lf
*.json          text eol=lf

# Windows scripts / MSBuild / DOTNET: CRLF
*.ps1           text eol=crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.sln           text eol=crlf
*.csproj        text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf